{
  "$schema": "https://opencode.ai/config.json",
  "shell": "xonsh",
  "instructions": ["~/dotfiles/.config/opencode/SYSTEM.md"],
  "default_agent": "plan",
  "agent": {
    "product-manager": { "mode": "primary" },
    "tech-lead": { "mode": "primary" },
    "code-reviewer": {"mode": "primary"},
    "architect-designer": {"mode": "subagent"},
    "implementation-specialist": {"mode": "subagent"},
    "qa-engineer": {"mode": "subagent"}
  },
  "permission": {
    "bash": {
      "*": "ask",

      "git *": "allow",
      "wt *": "allow",

      "ls *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "whoami": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "df *": "allow",
      "find *": "allow",
      "tree *": "allow",

      "git push *": "ask",
      "git reset --hard *": "deny",
      "git clean -fd *": "deny",
      "git clean -fdx *": "deny",
      "sudo *": "deny",
      "shutdown *": "deny",
      "reboot *": "deny"
    },
    "glob": "allow",
    "read": "allow",
    "grep": "allow"
  },
  "mcp": {
    "gh_personal": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_PAT}"
      }
    }
  }
}
