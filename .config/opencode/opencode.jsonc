{
  "$schema": "https://opencode.ai/config.json",
  "shell": "xonsh",
  "instructions": ["~/dotfiles/.config/opencode/SYSTEM.md"],
  "default_agent": "plan",
  "agent": {
    "product-manager": { "mode": "primary" },
    "tech-lead": { "mode": "primary" },
    "code-reviewer": {"mode": "primary"},
    "architect-designer": {"mode": "subagent"},
    "implementation-specialist": {"mode": "subagent"},
    "qa-engineer": {"mode": "subagent"}
  },
  "permission": {
    "bash": {
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "git worktree*": "allow",
      "ls*": "allow",
      "pwd": "allow",
      "whoami": "allow",
      "cat /etc/os-release": "allow",
      "uname*": "allow",
      "which*": "allow",
      "file*": "allow",
      "df*": "allow",
      "du*": "allow",
      "stat*": "allow",
      "wc*": "allow",
      "tree*": "allow",
      "*": "deny"
    },
    "glob": "allow",
    "read": "allow",
    "grep": "allow"
  },
  "mcp": {
    "gh_personal": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_PAT}"
      }
    }
  }
}
