# XONSH WEBCONFIG START
$XONSH_COLOR_STYLE = 'lightbulb'
$PROMPT = '{env_name}{BOLD_GREEN}{user}@{hostname}{BOLD_BLUE} {cwd}{branch_color}{gitstatus: {}}{RESET} {BOLD_BLUE}{prompt_end}{RESET} '
# XONSH WEBCONFIG END

# Unreal Engine
$UE_ROOT = f"{$HOME}/Apps/Unreal"
$SDL_VIDEODRIVER = "x11"

aliases["ue"] = [
    "env",
    "SDL_VIDEODRIVER=x11",
    f"{$HOME}/Apps/Unreal/Engine/Binaries/Linux/UnrealEditor",
]

# Use homebrew neovim (0.12+) instead of system version
aliases["nvim"] = "/home/linuxbrew/.linuxbrew/bin/nvim"
