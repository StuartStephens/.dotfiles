# XONSH WEBCONFIG START
$XONSH_COLOR_STYLE = 'github-dark'
$PROMPT = '{env_name}{BOLD_PURPLE}{user}@{hostname}{BOLD_GREEN} {cwd}{branch_color}{gitstatus: {}}{RESET} {BOLD_BLUE}{prompt_end}{RESET} '
# XONSH WEBCONFIG END

# Unreal Engine
$UE_ROOT = f"{$HOME}/Apps/Unreal"
$SDL_VIDEODRIVER = "x11"

aliases["ue"] = [
    "env",
    "SDL_VIDEODRIVER=x11",
    f"{$HOME}/Apps/Unreal/Engine/Binaries/Linux/UnrealEditor",
]
